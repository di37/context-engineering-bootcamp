graph TD
    TASK["🎯 Current Task"]

    TASK --> Q1{"Analyzing results<br/>of past experiments?"}
    TASK --> Q2{"Sub-agent performing<br/>code review or research?"}
    TASK --> Q3{"Main context window<br/>too full for a subtask?"}

    Q1 -->|Yes| ISO1["🔒 Isolate into sub-agent"]
    Q2 -->|Yes| ISO2["🔒 Isolate into sub-agent"]
    Q3 -->|Yes| ISO3["🔒 Isolate into sub-agent"]

    ISO1 --> R1["Main task context<br/>would pollute the analysis"]
    ISO2 --> R2["Sub-agent needs a<br/>clean, focused context"]
    ISO3 --> R3["Prevents context rot<br/>in the main task"]

    Q1 -->|No| KEEP["✅ Keep in main<br/>context window"]
    Q2 -->|No| KEEP
    Q3 -->|No| KEEP

