    style D7 fill:#D1FAE5,stroke:#059669,color:#0B1E3D
    style D8 fill:#D1FAE5,stroke:#059669,color:#0B1E3D
    style IDX fill:#FEF3C7,stroke:#D97706,stroke-width:3px,color:#0B1E3D
