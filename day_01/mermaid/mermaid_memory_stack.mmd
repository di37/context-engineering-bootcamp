%%{init: {
  "theme": "base",
  "themeVariables": {
    "primaryColor": "#E8EDF3",
    "primaryTextColor": "#1a2744",
    "primaryBorderColor": "#8696b0",
    "lineColor": "#1a2744",
    "fontFamily": "Helvetica, Arial, sans-serif",
    "fontSize": "18px"
  },
  "flowchart": {
    "nodeSpacing": 50,
    "rankSpacing": 70,
    "padding": 30
  }
