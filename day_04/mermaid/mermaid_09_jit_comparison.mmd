    end
    style SP1 fill:#FEE2E2,stroke:#EF4444,stroke-width:2px,color:#0B1E3D
    style SP2 fill:#D1FAE5,stroke:#10B981,stroke-width:2px,color:#0B1E3D
    style TR fill:#F0F9FF,stroke:#0891B2,stroke-width:2px,color:#0B1E3D
