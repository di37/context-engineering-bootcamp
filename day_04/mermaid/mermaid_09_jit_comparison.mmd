%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#E8EDF3", "primaryTextColor": "#0B1E3D", "primaryBorderColor": "#8696b0", "lineColor": "#0B1E3D", "fontFamily": "Helvetica, Arial, sans-serif", "fontSize": "16px"}, "flowchart": {"nodeSpacing": 40, "rankSpacing": 50}}}%%
flowchart TD
    subgraph "Without JIT"
        SP1["System Prompt<br/>All 100 tool instructions<br/>~10K-20K tokens"]
